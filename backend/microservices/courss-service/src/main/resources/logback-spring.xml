<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Suppress LoadBalancer cache warning -->
    <logger name="org.springframework.cloud.loadbalancer.configuration.LoadBalancerCaffeineWarnLogger" level="ERROR"/>
    
    <!-- Suppress Hibernate dialect version warnings -->
    <logger name="org.hibernate.dialect.Dialect" level="ERROR"/>
    
    <!-- Reduce Eureka connection error verbosity (still shows errors but less verbose) -->
    <logger name="com.netflix.discovery.shared.transport.decorator.RetryableEurekaHttpClient" level="ERROR"/>
    
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>

